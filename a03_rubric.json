    "Grade Report": {
      "content_checks": [
        {
          "field": "I/P/O comment block",
          "regexes": [
            "'''[\\s\\S]*inputs[\\s\\S]*processes[\\s\\S]*outputs[\\s\\S]*'''",
            "\"\"\"[\\s\\S]*inputs[\\s\\S]*processes[\\s\\S]*outputs[\\s\\S]*\"\"\""
          ],
          "points": 3
        },
        {
          "field": "for loop present",
          "regexes": ["\\bfor\\b\\s+\\w+\\s+\\bin\\b"],
          "points": 0,
          "warn_only": true,
          "warn_message": "No for loop detected. This assignment requires at least one for loop."
        },
        {
          "field": "list or dict usage",
          "regexes": ["\\[|\\{|append|dict|list"],
          "points": 0,
          "warn_only": true,
          "warn_message": "No list or dictionary detected. This assignment requires at least one collection."
        }
      ],
      "test_cases": [
        {
          "label": "3 students with varied scores",
          "inputs": "3\nAlice\n92\nBob\n78\nCarol\n95\n",
          "expected_output": "(?i)(average|avg|mean).*\\d",
          "points": 3,
          "type": "output_check"
        },
        {
          "label": "highest score in output",
          "inputs": "3\nAlice\n92\nBob\n78\nCarol\n95\n",
          "expected_output": "(?i)(high|max|best|top).*(?:carol|95)",
          "points": 3,
          "type": "output_check"
        },
        {
          "label": "runs with 1 student",
          "inputs": "1\nEve\n85\n",
          "expected_output": ".+",
          "points": 2,
          "type": "output_check"
        }
      ]
    },
